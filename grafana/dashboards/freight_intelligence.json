          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    origin_name || ' → ' || destination_name as corridor,\n    round(max(case when mode_name = 'Multimodal' then mode_share_pct end)::numeric, 1) as \"Multimodal\",\n    round(max(case when mode_name = 'Truck' then mode_share_pct end)::numeric, 1) as \"Truck\",\n    round(max(case when mode_name = 'Water' then mode_share_pct end)::numeric, 1) as \"Water\",\n    round(max(case when mode_name = 'Pipeline' then mode_share_pct end)::numeric, 1) as \"Pipeline\",\n    round(max(case when mode_name = 'Rail' then mode_share_pct end)::numeric, 1) as \"Rail\"\nFROM gold.fct_mode_share\nWHERE year = 2024\nAND origin_zone != destination_zone\nAND corridor_total_tons > 100000\nGROUP BY origin_name, destination_name\nORDER BY max(corridor_total_tons) DESC\nLIMIT 5",
